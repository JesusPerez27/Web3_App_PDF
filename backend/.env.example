# Copia este archivo como .env y sustituye los valores.
# PORT=3001

# Sepolia (Infura o Alchemy)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY
# PRIVATE_KEY=tu_clave_privada_sin_0x
# CONTRACT_ADDRESS=0x_direccion_del_contrato_PdfRegistry

# Pinata (IPFS)
# PINATA_JWT=eyJ...tu_jwt_de_pinata

# Opcional: direcciones de contratos anteriores para verificación (ya no necesario;
# el backend lee automáticamente desde frontend/deployments/)
# CONTRACT_ADDRESSES_VERIFY=0xanterior1,0xanterior2
