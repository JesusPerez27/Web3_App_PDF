# ============================================
# CONFIGURACIÓN DE BLOCKCHAIN (Hardhat + Backend)
# ============================================

# URL del proveedor RPC de Sepolia
# Ejemplos:
#   Infura: https://sepolia.infura.io/v3/TU_PROJECT_ID
#   Alchemy: https://eth-sepolia.g.alchemy.com/v2/TU_PROJECT_ID
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/TU_PROJECT_ID

# Clave privada de tu wallet (SIN el prefijo 0x)
# IMPORTANTE:
#   - Usa SIEMPRE una wallet de pruebas
#   - Nunca subas este archivo a GitHub
PRIVATE_KEY=tu_clave_privada_sin_0x

# Dirección del contrato PdfRegistry desplegado
# Se autocompleta cuando ejecutes scripts/deploy.js,
# pero puedes pegarla manualmente si lo necesitas.
CONTRACT_ADDRESS=0x_direccion_del_contrato_desplegado


# ============================================
# CONFIGURACIÓN DE ETHERSCAN / POLYGONSCAN
# ============================================

# API Key de Etherscan para verificación de contratos (Sepolia, Goerli)
# Consíguela en: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=tu_etherscan_api_key

# (Opcional) API Key de Polygonscan si usas Mumbai
POLYGONSCAN_API_KEY=tu_polygonscan_api_key


# ============================================
# CONFIGURACIÓN DE IPFS (Pinata) PARA BACKEND
# ============================================

# JWT de Pinata para subir PDFs a IPFS
# Desde: https://app.pinata.cloud/keys  (Create new key -> JWT)
PINATA_JWT=tu_pinata_jwt_aqui


# ============================================
# CONFIGURACIÓN DEL BACKEND (Node/Express)
# ============================================

# Puerto del backend
PORT=3001


# ============================================
# CONFIGURACIÓN OPCIONAL DE OTRAS REDES
# (solo si quieres usar Goerli / Mumbai)
# ============================================

# Goerli (opcional)
GOERLI_RPC_URL=https://goerli.infura.io/v3/TU_PROJECT_ID

# Mumbai (opcional - Polygon testnet)
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/TU_PROJECT_ID


# ============================================
# CONFIGURACIÓN OPCIONAL DEL GAS REPORTER
# ============================================

# Habilitar reporte de gas en tests (true/false)
REPORT_GAS=false

# API Key de CoinMarketCap para mostrar precios en USD
COINMARKETCAP_API_KEY=tu_coinmarketcap_api_key